@model IEnumerable<CMS.Data.Entities.CategoryProduct>

@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-5">
        <div>
            <h2 class="fw-bold text-uppercase mb-1">
                Danh mục sản phẩm
            </h2>
            <p class="text-muted mb-0">
                Tổng cộng @(Model?.Count() ?? 0) danh mục
            </p>
        </div>
        <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-circle me-2"></i> Thêm danh mục
        </a>
    </div>

    <div class="row">

        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">

                    <div class="card shadow border-0 rounded-4 h-100 category-card">

                        <div class="card-body p-4">

                            <div class="icon-box mb-3">
                                <i class="bi bi-grid-fill"></i>
                            </div>

                            <h4 class="fw-bold">
                                @item.Name
                            </h4>

                            <p class="text-muted">
                                @item.Description
                            </p>

                        </div>

                        <div class="card-footer bg-transparent border-0 px-4 pb-4">
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning w-50 rounded-pill text-white">
                                    <i class="bi bi-pencil-square me-1"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger w-50 rounded-pill" onclick="return confirm('Bạn có chắc muốn xóa danh mục này không?')">
                                    <i class="bi bi-trash me-1"></i> Xóa
                                </a>
                            </div>
                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">

                <h4 class="text-muted">
                    Chưa có danh mục nào
                </h4>

            </div>
        }

    </div>

</div>

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>

    body {
        background: #f8f9fc;
    }

    .category-card {
        transition: all 0.3s ease;
    }

        .category-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
        }

    .icon-box {
        width: 70px;
        height: 70px;
        background: #4e73df;
        color: white;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
    }

</style>
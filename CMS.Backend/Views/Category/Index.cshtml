@model IEnumerable<CMS.Data.Entities.Category>

@* @{
    ViewData["Title"] = "Quản lý danh mục";
} *@
@{
    Layout = "_LayoutAdmin";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container mt-5">

    <div class="category-card shadow-sm border-0">

        <!-- HEADER -->
        <div class="category-header">

            <div class="d-flex justify-content-between align-items-center">

                <div>

                    <h3 class="mb-0 text-white fw-bold">

                        <i class="fas fa-folder-open me-2"></i>

                        DANH SÁCH DANH MỤC

                    </h3>

                    <p class="text-white-50 small mb-0">
                        Quản lý phân loại bài viết và sản phẩm
                    </p>

                </div>

                <!-- CREATE BUTTON -->
                <a asp-action="Create"
                   class="btn btn-add-new">

                    <i class="fas fa-plus-circle me-1"></i>

                    Thêm danh mục

                </a>

            </div>

        </div>

        <!-- TABLE -->
        <div class="p-0">

            <table class="table table-hover mb-0 custom-category-table">

                <thead>

                    <tr>

                        <th style="width:10%" class="ps-4">
                            ID
                        </th>

                        <th style="width:30%">
                            Tên danh mục
                        </th>

                        <th style="width:40%">
                            Mô tả chi tiết
                        </th>

                        <th style="width:20%" class="text-end pe-4">
                            Thao tác
                        </th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <!-- ID -->
                                <td class="ps-4">

                                    <span class="badge bg-light text-dark border">
                                        #@item.Id
                                    </span>

                                </td>

                                <!-- NAME -->
                                <td>

                                    <span class="fw-bold text-primary">
                                        @item.Name
                                    </span>

                                </td>

                                <!-- DESCRIPTION -->
                                <td>

                                    <span class="text-muted d-inline-block text-truncate"
                                          style="max-width: 300px;">

                                        @item.Description

                                    </span>

                                </td>

                                <!-- ACTION -->
                                <td class="text-end pe-4">

                                    <div class="btn-group">

                                        <!-- EDIT -->
                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-warning btn-sm mx-1">

                                            <i class="fas fa-edit"></i>

                                        </a>

                                        <!-- DELETE -->
                                        <a asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-danger btn-sm mx-1"
                                           onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này?')">

                                            <i class="fas fa-trash-alt"></i>

                                        </a>

                                    </div>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="4" class="text-center py-5">

                                <i class="fas fa-folder-open display-5 text-muted mb-3"></i>

                                <p class="text-muted mb-0">
                                    Chưa có danh mục nào trong hệ thống.
                                </p>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

        <!-- FOOTER -->
        <div class="card-footer bg-white py-3 text-center border-top">

            <small class="text-muted">

                Hiển thị @Model.Count() danh mục dữ liệu

            </small>

        </div>

    </div>

</div>

<style>

    body {
        background: #f4f6f9;
    }

    .category-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
    }

    .category-header {
        background: linear-gradient(45deg, #2c3e50, #4ca1af);
        padding: 1.5rem 2rem;
    }

    .btn-add-new {
        background: #fff;
        color: #2c3e50;
        border: none;
        padding: 10px 22px;
        border-radius: 10px;
        font-weight: 600;
        transition: 0.3s ease;
        text-decoration: none;
    }

        .btn-add-new:hover {
            background: #f8f9fa;
            transform: translateY(-2px);
            box-shadow: 0 5px 12px rgba(0,0,0,0.2);
            color: #2c3e50;
        }

    .custom-category-table thead {
        background-color: #f8fbfd;
    }

        .custom-category-table thead th {
            font-size: 0.85rem;
            text-transform: uppercase;
            color: #6c757d;
            font-weight: 700;
            padding: 16px 10px;
            border-bottom: 2px solid #edf2f9;
        }

    .custom-category-table tbody tr {
        transition: 0.2s ease;
    }

        .custom-category-table tbody tr:hover {
            background-color: #f0f7ff;
        }

    .custom-category-table td {
        padding: 18px 10px;
        vertical-align: middle;
        border-bottom: 1px solid #edf2f9;
    }

    .btn-group .btn {
        border-radius: 8px;
        transition: 0.25s ease;
    }

        .btn-group .btn:hover {
            transform: scale(1.1);
        }
</style>
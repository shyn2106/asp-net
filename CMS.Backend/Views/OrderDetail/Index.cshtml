@model IEnumerable<CMS.Data.Entities.OrderDetail>

@{
    Layout = "_LayoutAdmin";
}

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container mt-5">

    <div class="detail-card shadow-lg border-0">

        <!-- HEADER -->
        <div class="header-custom">

            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                <div>

                    <h2 class="text-white fw-bold mb-1">
                        <i class="fas fa-file-invoice-dollar me-2"></i>
                        Chi tiết đơn hàng
                    </h2>

                    <small class="text-white-50">
                        Tổng cộng @(Model?.Count() ?? 0) chi tiết
                    </small>

                </div>

            </div>

        </div>

        <!-- TABLE -->
        <div class="table-responsive p-4">

            <table class="table table-hover align-middle custom-table">

                <thead>
                    <tr>
                        <th>Mã C.Tiết</th>
                        <th>Khách hàng</th>
                        <th>Sản phẩm</th>
                        <th>Số lượng</th>
                        <th>Đơn giá</th>
                        <th>Thành tiền</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var total = item.Quantity * item.UnitPrice;

                            <tr>

                                <td class="fw-bold text-muted">
                                    #@item.Id
                                </td>

                                <td>
                                    <div class="fw-bold">@item.Order?.Customer?.FullName</div>
                                    <div class="small text-muted">ĐH: #@item.OrderId</div>
                                </td>

                                <td>
                                    <div class="fw-bold text-dark">@(item.Product?.Name ?? "Sản phẩm không tồn tại")</div>
                                </td>

                                <td>
                                    @item.Quantity
                                </td>

                                <td class="text-primary fw-bold">
                                    @item.UnitPrice.ToString("N0") ₫
                                </td>

                                <td class="text-success fw-bold">
                                    @total.ToString("N0") ₫
                                </td>

                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-controller="OrderDetail" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-pill px-3 shadow-sm">
                                            <i class="fas fa-eye me-1"></i> Xem
                                        </a>
                                        @if (item.Order?.Status != 3 && item.Order?.Status != 2)
                                        {
                                            <form asp-controller="OrderDetail" asp-action="Delete" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa chi tiết này? Sản phẩm sẽ được hoàn lại kho.');">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 shadow-sm">
                                                    <i class="fas fa-trash-alt me-1"></i> Xóa
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="7"
                                class="text-center py-5 text-muted">

                                <i class="fas fa-receipt fs-1 d-block mb-3"></i>

                                Chưa có dữ liệu chi tiết đơn hàng

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<style>

    body {
        background: #f8f9fc;
    }

    .detail-card {
        border-radius: 18px;
        overflow: hidden;
        background: white;
    }

    .header-custom {
        background: linear-gradient(135deg, #36b9cc, #258391);
        padding: 1.5rem 2rem;
    }

    .custom-table thead th {
        background: #f8f9fc;
        color: #36b9cc;
        text-transform: uppercase;
        font-size: 13px;
        border-top: none;
    }

    .custom-table tbody tr {
        transition: all 0.2s ease;
    }

        .custom-table tbody tr:hover {
            background: #f8feff;
            transform: scale(1.002);
        }

</style>
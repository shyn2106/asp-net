@model CMS.Data.Entities.OrderDetail

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết một mục sản phẩm #" + Model.Id;
    decimal total = Model.Quantity * Model.UnitPrice;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">
            <i class="fas fa-list-alt text-info me-2"></i> Thông tin dòng mục mua hàng #@Model.Id
        </h2>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 fw-bold shadow-sm me-2">
                <i class="fas fa-arrow-left me-2"></i> Quay lại
            </a>
            <a asp-controller="Order" asp-action="Details" asp-route-id="@Model.OrderId" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                <i class="fas fa-eye me-2"></i> Xem toàn bộ đơn hàng
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- PRODUCT INFO -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 h-100">
                <div class="card-header bg-info text-white p-3 rounded-top-4">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-box me-2"></i> Thông tin sản phẩm</h5>
                </div>
                <div class="card-body p-4 bg-white rounded-bottom-4 text-center">
                    <img src="@(Model.Product?.ImageUrl ?? "/images/placeholder.jpg")" class="img-fluid rounded-4 shadow-sm mb-4" style="max-height: 250px; object-fit: cover;" alt="Product Image" />
                    
                    <h4 class="fw-bold text-dark mb-2">@(Model.Product?.Name ?? "Sản phẩm không xác định")</h4>
                    
                    <div class="d-flex justify-content-center align-items-center gap-4 mt-4">
                        <div class="text-center p-3 rounded-3" style="background: #f8f9fc;">
                            <small class="text-muted text-uppercase d-block fw-bold mb-1">Đơn giá</small>
                            <h5 class="text-primary fw-bold mb-0">@Model.UnitPrice.ToString("N0") ₫</h5>
                        </div>
                        <div class="text-center p-3 rounded-3" style="background: #f8f9fc;">
                            <small class="text-muted text-uppercase d-block fw-bold mb-1">Số lượng</small>
                            <h5 class="text-dark fw-bold mb-0">@Model.Quantity</h5>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light p-4 text-center border-0 rounded-bottom-4">
                    <small class="text-muted text-uppercase d-block fw-bold mb-1">Thành tiền dòng này</small>
                    <h3 class="text-danger fw-black mb-0">@total.ToString("N0") ₫</h3>
                </div>
            </div>
        </div>

        <!-- ORDER & CUSTOMER INFO -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 h-100">
                <div class="card-header bg-dark text-white p-3 rounded-top-4">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-receipt me-2"></i> Thông tin liên quan</h5>
                </div>
                <div class="card-body p-4 bg-white rounded-bottom-4">
                    <h6 class="text-uppercase fw-bold text-info mb-3 border-bottom pb-2">Đơn hàng chứa món này</h6>
                    <ul class="list-group list-group-flush mb-4">
                        <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                            <span class="text-muted"><i class="fas fa-hashtag me-2"></i> Mã đơn hàng</span>
                            <span class="fw-bold">#@Model.OrderId</span>
                        </li>
                        <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                            <span class="text-muted"><i class="fas fa-calendar-alt me-2"></i> Ngày đặt</span>
                            <span class="fw-bold">@(Model.Order?.OrderDate.ToString("dd/MM/yyyy HH:mm"))</span>
                        </li>
                        <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                            <span class="text-muted"><i class="fas fa-info-circle me-2"></i> Trạng thái</span>
                            @if (Model.Order?.Status == 2)
                            {
                                <span class="badge bg-success rounded-pill px-3 py-2">Đã hoàn thành</span>
                            }
                            else if (Model.Order?.Status == 1)
                            {
                                <span class="badge bg-info rounded-pill px-3 py-2">Đang giao</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark rounded-pill px-3 py-2">Chờ xử lý</span>
                            }
                        </li>
                    </ul>

                    <h6 class="text-uppercase fw-bold text-info mb-3 border-bottom pb-2">Khách hàng</h6>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                            <span class="text-muted"><i class="fas fa-user me-2"></i> Họ và tên</span>
                            <span class="fw-bold">@(Model.Order?.Customer?.FullName ?? "Không rõ")</span>
                        </li>
                        <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                            <span class="text-muted"><i class="fas fa-phone-alt me-2"></i> Số điện thoại</span>
                            <span class="fw-bold">@(Model.Order?.Customer?.Phone ?? "Không rõ")</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8f9fa; }
    .fw-black { font-weight: 900; }
</style>

@{
    Layout = "_LayoutAdmin";
}

<div class="access-denied-page">

    <div class="access-card">

        <div class="icon-box">
            <i class="bi bi-shield-lock-fill"></i>
        </div>

        <h1>
            403
        </h1>

        <h3>
            KHÔNG CÓ QUYỀN TRUY CẬP
        </h3>

        <p>
            Bạn không có đủ quyền hạn để xem trang này.
            <br />
            Vui lòng liên hệ quản trị viên.
        </p>

        <a href="/"
           class="btn-back">

            <i class="bi bi-house-door-fill me-2"></i>
            Quay lại trang chủ

        </a>

    </div>

</div>

<style>

    .access-denied-page {
        min-height: 80vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px;
    }

    .access-card {
        background: white;
        padding: 60px 50px;
        border-radius: 30px;
        text-align: center;
        max-width: 600px;
        width: 100%;
        box-shadow: 0 20px 50px rgba(0,0,0,0.1);
        animation: fadeIn 0.6s ease;
    }

    .icon-box {
        width: 110px;
        height: 110px;
        margin: auto;
        border-radius: 50%;
        background: rgba(220,53,69,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 25px;
    }

        .icon-box i {
            font-size: 55px;
            color: #dc3545;
        }

    .access-card h1 {
        font-size: 90px;
        font-weight: 800;
        color: #dc3545;
        margin-bottom: 10px;
    }

    .access-card h3 {
        font-weight: 700;
        margin-bottom: 20px;
        color: #1e293b;
    }

    .access-card p {
        color: #64748b;
        font-size: 17px;
        line-height: 1.7;
        margin-bottom: 35px;
    }

    .btn-back {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 14px 28px;
        border-radius: 999px;
        background: linear-gradient(135deg,#4e73df,#224abe);
        color: white;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-back:hover {
            transform: translateY(-3px);
            color: white;
            box-shadow: 0 10px 25px rgba(78,115,223,0.3);
        }

    @@keyframes fadeIn {

        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

</style>
@model CMS.Data.Entities.Post

@{
    ViewData["Title"] = "Chi tiết bài viết";
}

<div class="container mt-5 mb-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <!-- BACK BUTTON -->
            <a asp-action="Index"
               class="btn btn-link text-decoration-none p-0 mb-4 text-muted">

                <i class="bi bi-arrow-left"></i>
                Quay lại danh sách

            </a>

            <!-- IMAGE -->
            <div class="rounded-4 overflow-hidden shadow mb-4 detail-image">

                <img src="@(string.IsNullOrEmpty(Model.ImageUrl)
                                         ? "https://via.placeholder.com/1200x600?text=No+Image"
                                         : Model.ImageUrl)"
                     class="w-100 h-100 detail-img"
                     alt="@Model.Title" />

            </div>

            <!-- CATEGORY -->
            <span class="badge bg-primary px-3 py-2 mb-3">

                @(Model.Category != null
                                ? Model.Category.Name
                                : "Không có danh mục")

            </span>

            <!-- TITLE -->
            <h1 class="fw-bold mb-4 text-dark">

                @Model.Title

            </h1>

            <!-- META -->
            <div class="d-flex align-items-center flex-wrap mb-4 text-muted small">

                <div class="me-4 mb-2">

                    <i class="bi bi-calendar3 me-2"></i>

                    @Model.CreatedDate.ToString("dd/MM/yyyy")

                </div>

                <div class="mb-2">

                    <i class="bi bi-person-circle me-2"></i>

                    Admin CMS

                </div>

            </div>

            <!-- CONTENT -->
            <div class="content-box shadow-sm rounded-4 p-4 bg-white">

                <p class="lead text-dark mb-0 content-text">

                    @Html.Raw(Model.Content)

                </p>

            </div>

            <!-- ALERT -->
            <div class="alert alert-light border rounded-4 mt-5 p-4 shadow-sm">

                <h5 class="fw-bold mb-2">
                    Bạn thấy bài viết này hữu ích?
                </h5>

                <p class="mb-0 small text-muted">
                    Hãy chia sẻ kiến thức này đến bạn bè của bạn nhé!
                </p>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>

        .detail-image {
            height: 450px;
        }

        .detail-img {
            object-fit: cover;
            transition: transform 0.5s ease;
        }

            .detail-img:hover {
                transform: scale(1.03);
            }

        .content-box {
            border: 1px solid #f1f1f1;
        }

        .content-text {
            line-height: 1.9;
            text-align: justify;
            font-size: 18px;
        }

        .badge {
            font-size: 14px;
            border-radius: 50px;
        }
    </style>
}
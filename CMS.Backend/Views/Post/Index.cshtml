@model IEnumerable<CMS.Data.Entities.Post>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý bài viết";
}

<div class="container mt-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-3">

        <div>

            <h2 class="fw-bold text-uppercase mb-2"
                style="letter-spacing: 2px;">

                Quản lý bài viết

            </h2>

            <div class="bg-primary"
                 style="height: 3px; width: 70px;">
            </div>

            <p class="text-muted mt-2 mb-0">

                Tổng cộng có @(Model?.Count() ?? 0) bài viết

            </p>

        </div>

        <!-- BUTTON CREATE -->
        <a asp-action="Create"
           class="btn btn-primary rounded-pill px-4 shadow-sm">

            <i class="bi bi-plus-circle me-1"></i>

            Thêm bài viết mới

        </a>

    </div>

    <!-- POSTS -->
    <div class="row">

        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4">

                    <div class="card h-100 border-0 shadow-sm post-card">

                        <!-- IMAGE -->
                        <div class="position-relative overflow-hidden post-image">

                            <img src="@(string.IsNullOrEmpty(item.ImageUrl)
                                                                         ? "https://via.placeholder.com/400x250?text=No+Image"
                                                                         : item.ImageUrl)"
                                                                                         class="w-100 h-100 transition-img"
                                                                                         style="object-fit:cover;"
                                                                                         alt="@item.Title" />

                            <!-- CATEGORY -->
                            <div class="category-badge">

                                @(item.Category != null
                                                        ? item.Category.Name
                                                        : "Không có danh mục")

                            </div>

                        </div>

                        <!-- BODY -->
                        <div class="card-body p-4">

                            <!-- CATEGORY -->
                            <span class="badge bg-info text-dark mb-3">

                                @(item.Category != null
                                                        ? item.Category.Name
                                                        : "Không có danh mục")

                    </span>

                            <!-- TITLE -->
                            <h5 class="card-title fw-bold text-dark line-clamp-2">

                                @item.Title

                            </h5>

                            <!-- CONTENT -->
                            <div class="card-text text-secondary small line-clamp-3 mb-4">

                                @Html.Raw(item.Content)

                            </div>

                            <!-- DATE -->
                            <p class="text-muted small mb-0">

                                <i class="bi bi-calendar-event me-1"></i>

                                @item.CreatedDate.ToString("dd/MM/yyyy")

                            </p>

                        </div>

                        <!-- FOOTER -->
                        <div class="card-footer bg-transparent border-0 p-4 pt-0">

                            <div class="d-grid gap-2">

                                <!-- DETAIL -->
                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-dark rounded-pill py-2 fw-semibold shadow-sm">

                                    <i class="bi bi-eye me-1"></i>

                                    Đọc chi tiết

                                </a>

                                <!-- ACTION BUTTONS -->
                                <div class="d-flex gap-2">

                                    <!-- EDIT -->
                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-outline-warning flex-fill rounded-pill">

                                        <i class="bi bi-pencil-square me-1"></i>

                                        Sửa

                                    </a>

                                    <!-- DELETE -->
                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-outline-danger flex-fill rounded-pill"
                                       onclick="return confirm('Chúng ta có chắc chắn muốn xóa bài viết này không?')">

                                        <i class="bi bi-trash me-1"></i>

                                        Xóa

                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>
                }
        }
        else
        {
            <div class="col-12 text-center py-5">

                <i class="bi bi-folder-x display-1 text-light"></i>

                <p class="text-muted mt-3">

                    Hiện chưa có bài viết nào được đăng tải.

                </p>

            </div>
        }

    </div>

</div>

@section Scripts {

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>

        body {
            background: #f5f7fb;
        }

        .post-card {
            border-radius: 20px;
            transition: all 0.35s ease;
            overflow: hidden;
            background: #fff;
        }

            .post-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 20px 40px rgba(0,0,0,0.12) !important;
            }

        .post-image {
            height: 230px;
        }

        .transition-img {
            transition: transform 0.7s ease;
        }

        .post-card:hover .transition-img {
            transform: scale(1.08);
        }

        .category-badge {
            position: absolute;
            top: 15px;
            left: 15px;
            background: rgba(78,115,223,0.95);
            color: white;
            padding: 6px 16px;
            border-radius: 50px;
            font-size: 11px;
            font-weight: bold;
            letter-spacing: 0.5px;
        }

        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            min-height: 52px;
        }

        .line-clamp-3 {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
            min-height: 75px;
        }

        .btn-dark {
            background: #2c3e50;
            border: none;
            transition: all 0.3s ease;
        }

            .btn-dark:hover {
                background: #4e73df;
                transform: scale(1.02);
            }

        .btn-outline-warning:hover,
        .btn-outline-danger:hover {
            color: white;
        }

        .badge {
            font-size: 12px;
            padding: 8px 14px;
            border-radius: 50px;
        }
    </style>
}
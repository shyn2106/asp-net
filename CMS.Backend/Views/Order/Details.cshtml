@model CMS.Data.Entities.Order

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark mb-0">
            <i class="fas fa-file-invoice-dollar text-primary me-2"></i> Chi tiết đơn hàng #@Model.Id
        </h2>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 fw-bold shadow-sm">
            <i class="fas fa-arrow-left me-2"></i> Quay lại
        </a>
    </div>

    <div class="row g-4">
        <!-- Thông tin khách hàng & Đơn hàng -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-lg rounded-4 h-100">
                <div class="card-header bg-primary text-white p-3 rounded-top-4">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-info-circle me-2"></i> Thông tin chung</h5>
                </div>
                <div class="card-body p-4 bg-white rounded-bottom-4">
                    <div class="mb-3 border-bottom pb-2">
                        <small class="text-muted text-uppercase fw-bold">Trạng thái đơn hàng</small>
                        <div class="mt-2 mb-1">
                            <form asp-action="UpdateStatus" method="post" class="d-flex align-items-center gap-2">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <select name="status" class="form-select form-select-sm" style="max-width: 150px; font-weight: bold; @(Model.Status == 2 ? "color: #198754;" : (Model.Status == 1 ? "color: #0dcaf0;" : "color: #ffc107;"))">
                                    @if(Model.Status == 0) { <option value="0" selected>Chờ duyệt</option> } else { <option value="0">Chờ duyệt</option> }
                                    @if(Model.Status == 1) { <option value="1" selected>Đang giao</option> } else { <option value="1">Đang giao</option> }
                                    @if(Model.Status == 2) { <option value="2" selected>Đã hoàn thành</option> } else { <option value="2">Đã hoàn thành</option> }
                                </select>
                                <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm"><i class="fas fa-save me-1"></i> Lưu</button>
                            </form>
                        </div>
                    </div>

                    <div class="mb-3 border-bottom pb-2">
                        <small class="text-muted text-uppercase fw-bold">Ngày đặt</small>
                        <p class="mb-0 fw-bold text-dark mt-1">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>

                    <div class="mb-3 border-bottom pb-2">
                        <small class="text-muted text-uppercase fw-bold">Khách hàng</small>
                        <p class="mb-0 fw-bold text-dark mt-1">
                            <i class="fas fa-user-circle text-primary me-1"></i> @(Model.Customer?.FullName ?? "Khách vãng lai")
                        </p>
                        <p class="mb-0 text-muted small mt-1">
                            <i class="fas fa-phone-alt me-1"></i> @(Model.Customer?.Phone ?? "Không có SĐT")
                        </p>
                    </div>

                    <div>
                        <small class="text-muted text-uppercase fw-bold">Ghi chú của khách</small>
                        <p class="mb-0 fst-italic mt-1 @(string.IsNullOrEmpty(Model.Notes) ? "text-muted" : "text-dark")">
                            @(string.IsNullOrEmpty(Model.Notes) ? "Không có ghi chú" : Model.Notes)
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Danh sách sản phẩm -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 h-100">
                <div class="card-header bg-dark text-white p-3 rounded-top-4">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-box-open me-2"></i> Danh sách sản phẩm</h5>
                </div>
                <div class="card-body p-0 bg-white rounded-bottom-4 overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-muted text-uppercase small">
                                <tr>
                                    <th class="ps-4">Sản phẩm</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end">Thành tiền</th>
                                    <th class="text-center pe-4">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                                {
                                    decimal totalOrder = 0;
                                    foreach (var detail in Model.OrderDetails)
                                    {
                                        decimal lineTotal = detail.Quantity * detail.UnitPrice;
                                        totalOrder += lineTotal;
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <img src="@(detail.Product?.ImageUrl ?? "/images/placeholder.jpg")" alt="Product" class="rounded-3 shadow-sm me-3" style="width: 50px; height: 50px; object-fit: cover;">
                                                    <span class="fw-bold text-dark">@(detail.Product?.Name ?? "Sản phẩm đã xóa")</span>
                                                </div>
                                            </td>
                                            <td class="text-center py-3">
                                                <span class="badge bg-secondary rounded-pill px-3">@detail.Quantity</span>
                                            </td>
                                            <td class="text-end text-muted fw-bold py-3">
                                                @detail.UnitPrice.ToString("N0") đ
                                            </td>
                                            <td class="text-end text-danger fw-bold py-3">
                                                @lineTotal.ToString("N0") đ
                                            </td>
                                            <td class="text-center pe-4 py-3">
                                                <a href="http://localhost:5173/product/@detail.ProductId" target="_blank" class="btn btn-sm btn-outline-info rounded-pill px-3 shadow-sm">
                                                    <i class="fas fa-external-link-alt me-1"></i> Xem chi tiết
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                    <tr class="bg-light">
                                        <td colspan="3" class="text-end fw-bold py-4 text-uppercase">Tổng thanh toán:</td>
                                        <td colspan="2" class="text-end text-danger fw-black fs-5 pe-4 py-4">@totalOrder.ToString("N0") đ</td>
                                    </tr>
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">
                                            <i class="fas fa-ghost fs-1 d-block mb-3 text-secondary"></i>
                                            Đơn hàng này không có sản phẩm nào
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }
    .fw-black {
        font-weight: 900;
    }
</style>

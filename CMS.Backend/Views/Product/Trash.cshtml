@model IEnumerable<CMS.Data.Entities.Product>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thùng rác Sản phẩm";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container mt-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-5">

        <div>
            <h2 class="fw-bold text-uppercase mb-1 text-danger">
                <i class="fas fa-trash-alt me-2"></i> Thùng rác sản phẩm
            </h2>
            <p class="text-muted mb-0">
                Tổng cộng @(Model?.Count() ?? 0) sản phẩm đã xóa tạm
            </p>
        </div>

        <a asp-action="Index"
           class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-bold">
            <i class="fas fa-arrow-left me-2"></i> Quay lại Danh sách
        </a>

    </div>

    <!-- PRODUCTS -->
    <div class="row">

        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card product-card border-0 shadow-sm h-100 rounded-4" style="opacity: 0.85;">
                        <!-- IMAGE -->
                        <div class="position-relative overflow-hidden rounded-top-4" style="height:250px;">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl)
                                                                 ? "https://via.placeholder.com/400x250?text=No+Image"
                                                                 : item.ImageUrl)"
                                 class="w-100 h-100 product-img"
                                 style="object-fit:cover; filter: grayscale(100%);"
                                 alt="@item.Name" />
                            <div class="stock-badge bg-danger">
                                <i class="fas fa-times-circle me-1"></i> Đã xóa
                            </div>
                        </div>

                        <!-- BODY -->
                        <div class="card-body p-4">
                            <h4 class="fw-bold mb-2 line-clamp-2 text-decoration-line-through text-muted">
                                @item.Name
                            </h4>
                            <p class="text-muted small line-clamp-3">
                                @item.Description
                            </p>
                            <div class="mt-4 d-flex justify-content-between align-items-center">
                                <span class="price-tag text-muted">
                                    @item.Price.ToString("N0") ₫
                                </span>
                                @if (item.CategoryProduct != null)
                                {
                                    <span class="badge bg-secondary">
                                        @item.CategoryProduct.Name
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- FOOTER -->
                        <div class="card-footer bg-transparent border-0 px-4 pb-4">
                            <a asp-action="Restore"
                               asp-route-id="@item.Id"
                               class="btn btn-success w-100 rounded-pill fw-bold shadow-sm"
                               onclick="return confirm('Khôi phục sản phẩm này về danh sách chính?')">
                                <i class="fas fa-undo-alt me-1"></i> Khôi phục
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fas fa-box-open display-1 text-muted mb-3"></i>
                <h4 class="text-muted">
                    Thùng rác trống
                </h4>
            </div>
        }

    </div>
</div>

<style>
    body {
        background: #f8f9fc;
    }

    .product-card {
        transition: all 0.3s ease;
        overflow: hidden;
    }

    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        opacity: 1 !important;
    }
    .product-card:hover .product-img {
        filter: grayscale(0%) !important;
    }

    .stock-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        color: white;
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
    }

    .price-tag {
        font-size: 22px;
        font-weight: bold;
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 55px;
    }

    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 70px;
    }
</style>

@model IEnumerable<CMS.Data.Entities.Product>

@{
    Layout = "_LayoutAdmin";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="container mt-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-5">

        <div>

            <h2 class="fw-bold text-uppercase mb-1">
                Danh sách sản phẩm
            </h2>

            <p class="text-muted mb-0">
                Tổng cộng @(Model?.Count() ?? 0) sản phẩm
            </p>

        </div>

        <!-- ACTIONS -->
        <div class="d-flex gap-2">
            <a asp-action="Trash" class="btn btn-outline-danger rounded-pill px-4 shadow-sm fw-bold">
                <i class="fas fa-trash-restore me-2"></i> Thùng rác
            </a>

            <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm fw-bold">
                <i class="bi bi-plus-circle me-2"></i> Thêm sản phẩm
            </a>
        </div>
    </div>

    <!-- PRODUCTS -->
    <div class="row">

        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6 mb-4">

                    <div class="card product-card border-0 shadow-sm h-100 rounded-4">

                        <!-- IMAGE -->
                        <div class="position-relative overflow-hidden rounded-top-4"
                             style="height:250px;">

                            <img src="@(string.IsNullOrEmpty(item.ImageUrl)
                                                                 ? "https://via.placeholder.com/400x250?text=No+Image"
                                                                 : item.ImageUrl)"
                         class="w-100 h-100 product-img"
                         style="object-fit:cover;"
                         alt="@item.Name" />

                            <!-- STOCK -->
                            <div class="stock-badge">

                                <i class="bi bi-box-seam me-1"></i>

                                Kho: @item.StockQuantity

                            </div>

                        </div>

                        <!-- BODY -->
                        <div class="card-body p-4">

                            <h4 class="fw-bold mb-2 line-clamp-2">
                                @item.Name
                            </h4>

                            <p class="text-muted small line-clamp-3">
                                @item.Description
                            </p>

                            <div class="mt-4 d-flex justify-content-between align-items-center">

                                <span class="price-tag">
                                    @item.Price.ToString("N0") ₫
                                </span>

                        @if (item.CategoryProduct != null)
                                {
                                    <span class="badge bg-primary">
                                        @item.CategoryProduct.Name
                                    </span>
                                }

                            </div>

                        </div>

                        <!-- FOOTER -->
                        <div class="card-footer bg-transparent border-0 px-4 pb-4">

                            <div class="d-flex gap-2">

                                <!-- EDIT -->
                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning w-50 rounded-pill">

                                    <i class="fas fa-edit me-1"></i>

                                    Sửa

                                </a>

                                <!-- DELETE -->
                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger w-50 rounded-pill"
                                   onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này không?')">

                                    <i class="fas fa-trash me-1"></i>

                                    Xóa

                                </a>

                            </div>

                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">

                <i class="bi bi-box-seam display-1 text-muted"></i>

                <h4 class="mt-3 text-muted">
                    Chưa có sản phẩm nào
                </h4>

            </div>
        }

    </div>

</div>

<style>

    body {
        background: #f8f9fc;
    }

    .product-card {
        transition: all 0.3s ease;
        overflow: hidden;
    }

        .product-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.12) !important;
        }

    .product-img {
        transition: transform 0.6s ease;
    }

    .product-card:hover .product-img {
        transform: scale(1.08);
    }

    .stock-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: rgba(0,0,0,0.7);
        color: white;
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
    }

    .price-tag {
        color: #e74a3b;
        font-size: 22px;
        font-weight: bold;
    }

    .btn-warning {
        color: white;
    }

        .btn-warning:hover {
            background: #f6c23e;
            border-color: #f6c23e;
        }

    .btn-danger:hover {
        background: #e74a3b;
    }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 55px;
    }

    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 70px;
    }

</style>